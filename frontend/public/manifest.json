{
  "manifest_version": 3,
  "name": "Sting Shopify Bridge",
  "description": "Connect the Sting optimization report to Shopify Admin and prepare the next step for conversion fixes.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.myshopify.com/*",
    "https://*.shopify.com/*",
    "http://localhost:8000/*",
    "http://localhost:5173/*"
  ],
  "action": {
    "default_title": "Sting Bridge",
    "default_popup": "extension_popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.myshopify.com/*",
        "https://*.shopify.com/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
